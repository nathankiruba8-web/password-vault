# ==============================================================================
# SECURE PASSWORD VAULT - BACKEND ENVIRONMENTAL CONFIGURATION TEMPLATE
# ==============================================================================
# Copy this file to a new file named '.env' in this directory and populate
# with your actual configuration values. Do NOT commit the final '.env' file 
# containing real secrets to public source control systems.

# ------------------------------------------------------------------------------
# 1. SERVER CONFIGURATION
# ------------------------------------------------------------------------------
PORT=3000
NODE_ENV=production

# ------------------------------------------------------------------------------
# 2. PERSISTENT SYSTEM STORAGE (MongoDB Connection String)
# ------------------------------------------------------------------------------
MONGODB_URI=mongodb://localhost:27017/password-vault

# ------------------------------------------------------------------------------
# 3. CRYPTOGRAPHIC SECURE KEYS (Authentication and Encryption)
# ------------------------------------------------------------------------------
# JWT_SECRET: Private signing key for creating user authorization tokens
JWT_SECRET=your_32_character_jwt_signing_key_here

# ENCRYPTION_KEY: Primary key for symmetrical AES-256-GCM data encryption/decryption
ENCRYPTION_KEY=your_secure_aes_256_vault_encryption_key_here

# ------------------------------------------------------------------------------
# 4. NODEMAILER EMAIL ROUTING (Two-Factor Validation & Security Updates)
# ------------------------------------------------------------------------------
# In unconfigured/sandbox environments, these configurations fallback gracefully 
# to secure local output stream console logs instead of failing.
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=your_smtp_mailbox_username
SMTP_PASS=your_smtp_mailbox_password
SMTP_FROM=no-reply@securevault.local
